# Firebase Admin SDK
# Descargar desde Firebase Console → Configuración del proyecto → Cuentas de servicio
# NUNCA subir el .json al repositorio
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json
FIREBASE_PROJECT_ID=micartera-ar

# PPI API — obtener desde el portal de desarrolladores de Portfolio Personal
# https://clientapi.portfoliopersonal.com
PPI_API_KEY=
PPI_API_SECRET=
PPI_ACCOUNT_NUMBER=

# CORS — en producción usar el dominio de Firebase Hosting
ALLOWED_ORIGINS=["http://localhost:5173"]

# Intervalo de polling de precios (segundos) — referencia; el scheduler se configura en functions/
POLLING_INTERVAL=60

# UID del administrador — solo este usuario puede hacer POST /api/prices/refresh
# Copiar desde Firebase Console → Authentication → Users (columna "User UID")
ADMIN_UID=

# Clave de cifrado para datos sensibles en Firestore (portfolio, avg_costs, historial).
# Puede ser cualquier string largo — el backend deriva una clave Fernet estable via SHA-256.
# Para generar una clave Fernet válida directamente:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NUNCA commitear el valor real. Sin esta clave el backend rechaza leer datos cifrados.
DATA_ENCRYPTION_KEY=
