# Firebase Admin SDK — archivo descargado desde Firebase Console → Configuración → Cuentas de servicio
# NUNCA subir el archivo .json al repo
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json
FIREBASE_PROJECT_ID=micartera-ar

# PPI API — obtener desde el panel de PPI
PPI_API_KEY=
PPI_ACCOUNT_NUMBER=

# CORS — en producción usar el dominio de Firebase Hosting
ALLOWED_ORIGINS=["http://localhost:5173"]

# Intervalo de polling de precios (segundos)
POLLING_INTERVAL=60
