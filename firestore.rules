rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // --- Datos del usuario ---

    // Portfolio y catalizadores: el usuario puede leer y escribir los suyos
    match /users/{uid}/portfolio/{cat} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/catalysts/{doc} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/profile {
      allow read, write: if isOwner(uid);
    }

    // Eventos de seguridad: el usuario solo puede leer los suyos.
    // La escritura es exclusiva del backend/Cloud Functions (Admin SDK, bypass de reglas).
    match /users/{uid}/securityEvents/{eventId} {
      allow read:  if isOwner(uid);
      allow write: if false;
    }

    // --- Datos de mercado ---
    // Lectura para cualquier usuario autenticado.
    // Escritura exclusiva del backend/Cloud Functions via Admin SDK.
    match /market/{document=**} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // --- Cola de emails ---
    // Solo Admin SDK (Cloud Functions) puede leer y escribir.
    // Integración con Firebase Extension "Trigger Email from Firestore" o
    // con la Cloud Function on_security_event definida en functions/main.py.
    match /mail/{docId} {
      allow read, write: if false;
    }
  }
}
