rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Datos cifrados del usuario: solo backend Admin SDK.
    // El cliente accede por la API para que Firestore no exponga plaintext ni ciphertext.
    match /users/{uid}/portfolio/{document=**} {
      allow read, write: if false;
    }

    match /users/{uid}/meta/{docId} {
      allow read, write: if docId != "avg_costs"
        && docId != "portfolio_history"
        && isOwner(uid);
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/catalysts/{docId} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/fundamentals/{docId} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/securityEvents/{docId} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // Cotizaciones de mercado: lectura autenticada, escritura solo Admin SDK
    match /market/{document=**} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // Cola de emails: solo Admin SDK
    match /mail/{docId} {
      allow read, write: if false;
    }
  }
}
